<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.EstadiaHospedagem"
             Title="EstadiaHospedagem"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Purple200}">
    <VerticalStackLayout>
        <Label Text="Pousada Púrpura"
               FontFamily="Fleur"
               FontSize="50"
               TextColor="{StaticResource Purple100}"
               VerticalOptions="Center"
               HorizontalOptions="Center"/>
        <Label 
            Text="Estádia"
            TextColor="{StaticResource Purple100}"
            FontFamily="Courgette"
            FontSize="50"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Button 
            Margin="10"
            Text="Voltar" 
            Clicked="Button_Clicked"
            BackgroundColor="{StaticResource Purple100}"
            FontFamily="Kalam"
            FontSize="18"/>
    </VerticalStackLayout>
</ContentPage>