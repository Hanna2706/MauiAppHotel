<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.HospedagemContratada"
             Title="HospedagemContratada"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Purple200}">
             
    <VerticalStackLayout Padding="10">
        <Label Text="Pousada Púrpura"
               Margin="10"
               FontFamily="Fleur"
               FontSize="50"
               TextColor="{StaticResource Purple100}"
               HorizontalOptions="Center"/>
        <Label 
            Text="{Binding QuartoSelecionado.Descricao}"
            Margin="10"
            TextColor="{StaticResource Purple100}"
            FontFamily="Courgette"
            FontSize="40"
            HorizontalOptions="Center" />

        <Border 
            Padding="10"
            StrokeShape="RoundRectangle 10"
            Margin="10"
            BackgroundColor="{StaticResource Purple100}"
            >
            <StackLayout Orientation="Horizontal">
                <HorizontalStackLayout HorizontalOptions="CenterAndExpand">
                    <Label Text="Adultos: "
                           TextColor="{StaticResource Purple200}"/>
                    <Label Text="{Binding QntAdultos}"
                           TextColor="{StaticResource Purple300}"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout HorizontalOptions="CenterAndExpand">
                    <Label Text="Crianças: "
                           TextColor="{StaticResource Purple200}"/>
                    <Label Text="{Binding QntCriancas}"
                           TextColor="{StaticResource Purple300}"/>
                </HorizontalStackLayout>
            </StackLayout>
        </Border>

        <Border 
            Padding="10"
            StrokeShape="RoundRectangle 10"
            Margin="10"
            BackgroundColor="{StaticResource Purple100}">
            
            <Grid ColumnDefinitions="*, *, *"
                  RowDefinitions="Auto, Auto">
                <Label Grid.Row="0" Grid.Column="0" 
                       Text="Check-in:" 
                       TextColor="{StaticResource Purple200}"
                       HorizontalTextAlignment="Center"/>
                
                <Label Grid.Row="0" Grid.Column="1" 
                       Text="Check-out:" 
                       TextColor="{StaticResource Purple200}"
                       HorizontalTextAlignment="Center"/>
                
                <Label Grid.Row="0" Grid.Column="2" 
                       Text="Estadia" 
                       TextColor="{StaticResource Purple200}"
                       HorizontalTextAlignment="Center"/>

                <Label Grid.Row="1" Grid.Column="0" 
                       Text="{Binding DataCheckIn, StringFormat='{}{0:dd/MM/yyyy}'}" 
                       TextColor="{StaticResource Purple300}"
                       HorizontalTextAlignment="Center"/>
                
                <Label Grid.Row="1" Grid.Column="1" 
                       Text="{Binding DataCheckOut, StringFormat='{}{0:dd/MM/yyyy}'}" 
                       TextColor="{StaticResource Purple300}"
                       HorizontalTextAlignment="Center"/>
                
                <Label Grid.Row="1" Grid.Column="2" 
                       Text="{Binding Estadia}" 
                       TextColor="{StaticResource Purple300}"
                       HorizontalTextAlignment="Center"/>
                
            </Grid>
        </Border>

        <Border Margin="10"
                StrokeShape="RoundRectangle 10"
                Padding="10"
                BackgroundColor="{StaticResource Purple100}">
            
            <HorizontalStackLayout HorizontalOptions="Center">
                <Label Text="Valor Total:"
                       TextColor="{StaticResource Purple200}"/>
                <Label Text="{Binding ValorTotal, StringFormat='{}{0:c}'}"
                       TextColor="{StaticResource Purple300}"/>
            </HorizontalStackLayout>
        </Border>

        <Button Text="Voltar"
                HorizontalOptions="Center"
                Clicked="Button_Clicked"
                FontFamily="Kalam"
                FontSize="18"/>
    </VerticalStackLayout>
</ContentPage>